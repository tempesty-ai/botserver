# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  1단계 — 기본 연동 (필수)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OPENAI_API_KEY=sk-proj-...
ASSISTANT_ID=asst_...
MATTERMOST_TOKEN=your-mattermost-token

# 서버 설정
PORT=5000
POLL_TIMEOUT=120
POLL_INTERVAL=5

# 멀티 어시스턴트 라우팅 (선택)
# 예) {"장애":"asst_abc","성능":"asst_def","배포":"asst_ghi"}
ASSISTANT_ROUTES=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  2단계 — Function Calling (선택)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TOOLS_ENABLED=false

# call_webhook 툴이 호출할 수 있는 엔드포인트 목록
# 예) {"performance":"http://internal/api/perf","alert":"http://internal/api/alert"}
TOOL_WEBHOOKS=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  3단계 — 외부 커넥터 (선택, 하나라도 설정하면 활성화)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# [Local] 로컬 파일 검색 경로 (쉼표로 구분)
LOCAL_SEARCH_PATHS=/path/to/docs,/path/to/manuals

# [exemDocs] 내부 문서 시스템
EXEM_DOCS_URL=http://exem-docs-server/
EXEM_DOCS_API_KEY=

# [Google Drive] 서비스 계정 인증 파일 및 검색 대상 폴더 ID
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_DRIVE_FOLDER_ID=

# [ClickUp] API 토큰 및 워크스페이스 ID
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
